# 复制为 scripts/package.env 后生效，或通过环境变量临时覆盖。

APP_NAME="小火箭启动器"
EXECUTABLE_NAME="XYLaunch"
BUNDLE_ID="com.xylaunch.app"
VERSION="1.0.0"
BUILD_NUMBER="1"

# 可选: 指向你的品牌图标文件，支持 .icns/.png/.jpg/.jpeg
ICON_SOURCE="./Xcode/Resources/appicon.png"

# 可选: DMG 挂载盘名称
# VOLUME_NAME="小火箭启动器 Installer"

# 可选: 最低系统版本
MIN_SYSTEM_VERSION="13.0"
